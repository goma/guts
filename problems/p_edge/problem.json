{
  "name": "p_edge",
  "description": "3D Slot Coater Edge Bead",
  "contact": {
    "name": "Goma Developers",
    "email": "contact@gomafem.com"
  },
  "estimated_time_minutes": 2,
  "disabled": false,
  "features": [
    "gmres",
    "steady",
    "moving_mesh",
    "parallel",
    "3d",
    "cartesian",
    "no_chemkin"
  ],
  "requirements": {
    "max_prob_var": 7,
    "max_conc": 1,
    "mde": 27,
    "solver_package": "unknown",
    "use_arpack": "no",
    "enable_omega_h": ""
  },
  "run": {
    "use_aprepro": true,
    "aprepro_flags": "",
    "use_chemkin": false,
    "chemkin_input": "",
    "use_mpi": true,
    "num_processors": 2,
    "use_decomp": false,
    "brk_input": "brk_udp.in",
    "brk_exo_in": "contin.exoII",
    "fix_exo_basename": "out",
    "goma_input": "input",
    "goma_serr": "stderr.txt",
    "goma_sout": "stdout.txt",
    "goma_opts": ""
  },
  "blessed": {
    "serr": "blessed.stderr.txt",
    "sout": "blessed.stdout.txt",
    "exo_output": [
      "out.exoII",
      "anneal.exoII"
    ],
    "blessed_exo_output": [
      "blessed.exoII",
      "blessed_anneal.exoII"
    ],
    "exo_abs_tol": [
      1e-11
    ],
    "exo_rel_tol": [
      0.001
    ],
    "exodiff_input_file": [
      ""
    ]
  },
  "extra": {
    "whacked_files": [],
    "extra_tests": false,
    "extra_test_scripts": []
  }
}
