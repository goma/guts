Time Integration Specifications
---- ----------- --------------

Time integration                 = transient
delta_t                          = {time_step_init}
Maximum number of time steps     = {max_steps}
Maximum time                     = {total_time}
Minimum time step                = {time_step_min} 
Maximum time step                = {time_step_max}
Time step parameter              = {0.5*trapezoidal}
Time step error  		 = {time_step_error}
Printing Frequency               = 1
#Minimum Resolved Time Step       = {time_step_resolved}
$$Courant Number Limit             = 0.1
Restart Time Integration After Renormalization = no
Initial Time                     = {initial_time}

Steps of constant delta_t after failure	= 3
Time step decelerator		 = 0.5


$$Turbulence Calculate Wall Distance = yes
$$Turbulence Wall Node Sets = 20 5
$$Turbulence Wall Node Sets = 20


{Ifdef(use_TG)}
Fill Weight Function	         = Taylor-Galerkin
{Else}
Fill Weight Function	         = Galerkin
{Endif}
Fill Equation			 = Advection



Level Set Interface Tracking     = ON
Level Set Length Scale           = {LSLS}
{Ifdef(continue)}
Level Set Initialization Method  = Exodus
{Else}
Level Set Initialization Method  = Surfaces 1
	                        SURF = CIRCLE 0. 0.0  6.35
{Endif}
Level Set Control Width		 = 1.0
Level Set Timestep Control = YES
Level Set Renormalization Tolerance = {renorm_tol}
Level Set Renormalization Method = Huygens
Ignore Level Set Dependencies	 = FALSE
Level Set Renormalization Frequency = {renorm_freq}
Force Initial Level Set Renormalization = yes
Level Set Reconstruction Method  = POINTS
Level Set Contact Extension	 = FALSE

{Ifdef(use_subgrid)}
Level Set Subgrid Integration Depth = {subgrid_depth}
Level Set Subelement Integration = OFF
{Else}
Level Set Subelement Integration = ON
Level Set Adaptive Integration = OFF
Level Set Adaptive Order = 2
{Endif}
Overlap Quadrature Points = 0
Level Set PSPP filtering = NO
Level Set Toure Penalty             = off

{Ifdef(freeze)}
Huygens Freeze Nodes                = on
{Else}
Huygens Freeze Nodes                = off
{Endif}
Level Set Enable Div Term	= NO
Level Set Semi-Implicit Time Integration = NO

$$Turbulence Calculate Wall Distance = yes
$$Turbulence Wall Node Sets = 20 5

