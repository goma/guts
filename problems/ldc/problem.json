{
  "name": "ldc",
  "description": "######################################################\n#\n#             Linear Stability Analysis Example Problem\n#\n######################################################",
  "contact": {
    "name": "Goma Developers",
    "email": "contact@gomafem.com"
  },
  "estimated_time_minutes": 1,
  "disabled": false,
  "features": [
    "serial",
    "steady",
    "umf",
    "eigen",
    "cartesian",
    "2d",
    "no_chemkin"
  ],
  "requirements": {
    "max_prob_var": 3,
    "max_conc": 1,
    "mde": 12,
    "solver_package": "umfpack",
    "use_arpack": "no",
    "enable_omega_h": ""
  },
  "run": {
    "use_aprepro": true,
    "aprepro_flags": "",
    "use_chemkin": false,
    "chemkin_input": "",
    "use_mpi": false,
    "num_processors": 1,
    "use_decomp": false,
    "brk_input": "",
    "brk_exo_in": "",
    "fix_exo_basename": "",
    "goma_input": "ldc.input",
    "goma_serr": "stderr.txt",
    "goma_sout": "stdout.txt",
    "goma_opts": ""
  },
  "blessed": {
    "serr": "blessed.stderr.txt",
    "sout": "blessed.stdout.txt",
    "exo_output": [
      "out.exoII",
      "LSA_1_of_5_out.exoII"
    ],
    "blessed_exo_output": [
      "blessed.exoII",
      "blessed_LSA_1_of_5_out.exoII"
    ],
    "exo_abs_tol": [
      1e-11
    ],
    "exo_rel_tol": [
      0.001
    ],
    "exodiff_input_file": [
      "exodiff.inp",
      "exodiff_LSA.inp"
    ]
  },
  "extra": {
    "whacked_files": [],
    "extra_tests": true,
    "extra_test_scripts": [
      "egv_test.sh"
    ]
  }
}
