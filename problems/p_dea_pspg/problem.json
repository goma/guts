{
  "name": "p_dea_pspg",
  "description": "Species Source Test for DEA Epoxy Model w/PSPG Stabilization",
  "contact": {
    "name": "Goma Developers",
    "email": "contact@gomafem.com"
  },
  "estimated_time_minutes": 1,
  "disabled": false,
  "features": [
    "parallel",
    "transient",
    "cgs",
    "2d",
    "pspg",
    "species",
    "energy",
    "cylindrical",
    "moving_mesh",
    "no_chemkin"
  ],
  "requirements": {
    "max_prob_var": 6,
    "max_conc": 2,
    "mde": 12,
    "solver_package": "aztec",
    "use_arpack": "no",
    "enable_omega_h": ""
  },
  "run": {
    "use_aprepro": true,
    "aprepro_flags": "",
    "use_chemkin": false,
    "chemkin_input": "",
    "use_mpi": true,
    "num_processors": 2,
    "use_decomp": false,
    "brk_input": "brk_ctv.in",
    "brk_exo_in": "simple.exoII",
    "fix_exo_basename": "epoxy_out",
    "goma_input": "disk_pspg.input",
    "goma_serr": "stderr.txt",
    "goma_sout": "stdout.txt",
    "goma_opts": ""
  },
  "blessed": {
    "serr": "blessed.stderr.txt",
    "sout": "blessed.stdout.txt",
    "exo_output": [
      "epoxy_out.exoII"
    ],
    "blessed_exo_output": [
      "blessed.exoII"
    ],
    "exo_abs_tol": [
      1e-11
    ],
    "exo_rel_tol": [
      0.001
    ],
    "exodiff_input_file": [
      ""
    ]
  },
  "extra": {
    "whacked_files": [],
    "extra_tests": false,
    "extra_test_scripts": []
  }
}
