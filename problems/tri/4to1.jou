# ratio	      = {ratio       = 4}
# fore_length = {fore_length = 8}
# aft_length  = {aft_length  = 8}
# depth       = {depth       = 4}

## Geometry Creation
create brick x {fore_length} y {ratio} z {depth}
create brick x {aft_length}  y 1       z {depth}
move volume 1 x {-fore_length/2} y {ratio/2}
move volume 2 x {aft_length/2}   y {1/2}
unite volume 1 2
merge all
compress all

## Block Labling
block 1 surface 1 


surface 1 size {1/3}
##surface 1 scheme trimesh

mesh surface 1

sideset 10 curve 2  # xmin (inflow)
sideset 20 curve 8  # xmax (outflow)
sideset 30 curve 10 # ymin (bottom)
sideset 40 curve 1 18 9 # ymax (top)
nodeset 10 curve 2  # xmin (inflow)
nodeset 20 curve 8  # xmax (outflow)
nodeset 30 curve 10 # ymin (bottom)
nodeset 40 curve 1 18 9 # ymax (top)



##block 1 element type tri3
block 1 element type quad4

export genesis "4to1_quad4.e" dimension 2 overwrite

