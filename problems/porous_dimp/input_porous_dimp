Time Integration Specifications
---- ----------- --------------
Time integration                 = transient
delta_t                          = {dt_max/2.0}
Initial Time                     = 0.0
Maximum number of time steps     = 25
Maximum time                     = 5000.0
Minimum time step                = {dt_min/10.0} 
Maximum time step                = {dt_max}
Minimum Resolved Time Step       = {dt_min}
Time step parameter              = 0.0
Time step error  		 = -1.e-2  0   1   1   1   0   1 0
Printing Frequency               = 5
Fill Weight Function	         = Explicit
Courant Number Limit             = 0.2

Level Set Interface Tracking     = ON
Level Set Subelement Integration = OFF
Level Set Subgrid Integration Depth = 2
Level Set Length Scale           = {LSLS=0.12}
#Level Set Initialization Method = Exodus
Level Set Initialization Method = Surfaces 2
	                        SURF = ARC {cx1} {cy1} {r1} {nx1} {ny1} {d1} 
	                        SURF = ARC {cx2} {cy2} {r2} {nx2} {ny2} {d2} 
Level Set Renormalization Method = Huygens_Constrained
Level Set Renormalization Tolerance = 0.25
Level Set Renormalization Frequency = 1000000
Level Set Reconstruction Method  = POINTS
#Force Initial Level Set Renormalization = yes

