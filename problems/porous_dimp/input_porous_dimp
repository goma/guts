Boundary Condition Specifications
-------- --------- --------------
Number of BC                     = -1
######################################
## Level Set BC's

# Interface of porous & fluid

BC = POROUS_LIQ_PRESSURE_FILL SS 60 1 2 {-pcmin} {-pcmax} {2.0*LSLS}
BC = DARCY_CONTINUOUS SS 60 1 2 {0} {time_threshold}
#BC = VELO_NORMAL SS 60 0.0
BC = LINEAR_WETTING_SIC SS 60 {theta_s_ss60} {cT_ss60} {2.0*LSLS}  1.e-7  {0.0} 0.0  0.0 {dt_min/100.0}
#BC = VELO_SLIP_LS SS 60 {2.0*LSLS} 1.e4 0. 0. 0. 1.e-8
#BC = VELO_SLIP SS 60 1.e-6 0. 0. 0.

BC = U NS 100 {0.0}
BC = U NS 200 {0.0}
BC = LINEAR_WETTING_SIC SS 70 {theta_s_ss70} {cT_ss70} {2.0*LSLS} 1.e-7 {-planespeed} 0.0 0.0 {dt_min/100.0}
#BC = VELO_SLIP_LS SS 70 {2.0*LSLS} 1.e6 0. 0. 0. 1.e-8
BC = VELO_NORMAL SS 70 0.0


BC = V NS 30 0.0

BC = V NS 40 0.0


# Free Surface
BC = LS_CAPILLARY LS 0

# Mesh conditions


#     lower boundary 

BC = DY NS 70 0.0
BC = DX NS 70 0.0



#     left side
BC = DX NS 10 0.0

#     right side 

BC = DX NS 20 0.0


#    upper boundary

BC = GD_LINEAR SS 50 R_MESH2 0 MESH_POSITION2 0 {nominal_Y_ss50} -1.0
BC = GD_TABLE SS 50 R_MESH2 0 MESH_POSITION1 0 {scale_factor_ss50} LINEAR FILE = die_shape.dat

#porous/continuous boundary 

BC = GD_LINEAR SS 60 R_MESH2 0 MESH_POSITION2 0 {nominal_Y_ss60} -1.0
BC = GD_TABLE SS 60 R_MESH2 0 MESH_POSITION1 0 {scale_factor_ss60} LINEAR FILE = die_shape.dat



END OF BC
######################################

