{
  "name": "LSA_eggroll",
  "description": "Simple Rayleigh-Benard problem with stability analysis using\ninstalled eggroll shift & invert algorithm",
  "contact": {
    "name": "Goma Developers",
    "email": "contact@gomafem.com"
  },
  "estimated_time_minutes": 1,
  "disabled": false,
  "features": [
    "umf",
    "steady",
    "fixed_mesh",
    "serial",
    "2d",
    "cartesian",
    "no_chemkin",
    "eigen"
  ],
  "requirements": {
    "max_prob_var": 4,
    "max_conc": 1,
    "mde": 12,
    "solver_package": "unknown",
    "use_arpack": "no",
    "enable_omega_h": ""
  },
  "run": {
    "use_aprepro": true,
    "aprepro_flags": "",
    "use_chemkin": false,
    "chemkin_input": "",
    "use_mpi": false,
    "num_processors": 1,
    "use_decomp": false,
    "brk_input": "",
    "brk_exo_in": "",
    "fix_exo_basename": "",
    "goma_input": "eggroll.input",
    "goma_serr": "stderr.txt",
    "goma_sout": "stdout.txt",
    "goma_opts": ""
  },
  "blessed": {
    "serr": "blessed.stderr.txt",
    "sout": "blessed.stdout.txt",
    "exo_output": [
	"out.exoII"
    ],
    "blessed_exo_output": [
	"blessed.exoII"
    ],
    "exo_abs_tol": [
      1e-11
    ],
    "exo_rel_tol": [
      0.001
    ],
    "exodiff_input_file": [
      "exodiff.inp",
      "exodiff.inp"
    ]
  },
  "extra": {
    "whacked_files": [],
    "extra_tests": false,
    "extra_test_scripts": []
  }
}
