{
  "name": "static_bubble_s1",
  "description": "******************************************************\n*\n*  ALE interface relaxation in two phases using an\n*  internal boundary.\n*  Interface representing thermo equilibrium is a circle.\n*  We start with an oval, and then move the interface\n*  in time due to the capillary card.\n*\n******************************************************",
  "contact": {
    "name": "Goma Developers",
    "email": "contact@gomafem.com"
  },
  "estimated_time_minutes": 2,
  "disabled": false,
  "features": [
    "transient",
    "umf",
    "moving_mesh",
    "2d",
    "serial",
    "cartesian",
    "no_chemkin"
  ],
  "requirements": {
    "max_prob_var": 6,
    "max_conc": 3,
    "mde": 12,
    "solver_package": "umfpack",
    "use_arpack": "no",
    "enable_omega_h": ""
  },
  "run": {
    "use_aprepro": false,
    "aprepro_flags": "",
    "use_chemkin": false,
    "chemkin_input": "",
    "use_mpi": false,
    "num_processors": 1,
    "use_decomp": false,
    "brk_input": "",
    "brk_exo_in": "",
    "fix_exo_basename": "",
    "goma_input": "bubble_4c_short.inp",
    "goma_serr": "stderr.txt",
    "goma_sout": "stdout.txt",
    "goma_opts": ""
  },
  "blessed": {
    "serr": "blessed.stderr.txt",
    "sout": "blessed.stdout.txt",
    "exo_output": [
      "bubble_4c_short.exoII"
    ],
    "blessed_exo_output": [
      "blessed.exoII"
    ],
    "exo_abs_tol": [
      1e-11
    ],
    "exo_rel_tol": [
      0.001
    ],
    "exodiff_input_file": [
      "exodiff.inp"
    ]
  },
  "extra": {
    "whacked_files": [],
    "extra_tests": false,
    "extra_test_scripts": []
  }
}
