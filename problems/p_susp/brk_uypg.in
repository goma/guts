# eqnvar interaction specification
#
#    U     c     P    Sh
     1     1     1     0  #   momentum equation
     1     1     0     1  #    species equation
     1     0     1     0  # continuity equation
     1     0     0     1  # shear rate equation
 
 9   # number of nodes per element
 0 4 9 30
 0 4 9 30
 0 4 9 30
 0 4 9 30
