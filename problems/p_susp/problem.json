{
  "name": "p_susp",
  "description": "Suspension Model Test",
  "contact": {
    "name": "Goma Developers",
    "email": "contact@gomafem.com"
  },
  "estimated_time_minutes": 1,
  "disabled": false,
  "features": [
    "parallel",
    "transient",
