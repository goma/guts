# zero position is at left of inlet for slide 1

reset
nodeset associativity on
set associativity complete on
# {include(phys_prop.inc)}
create vertex 0 0 0 
create vertex 0 {L_slot_1} 0
create vertex {W_slot_1} 0 0
create vertex {W_slot_1} {L_slot_1} 0
create vertex {W_slot_1+R_slot_1} {L_slot_1+R_slot_1} 0
# center of fillet
create vertex {W_slot_1+R_slot_1} {L_slot_1} 0
# curve on center of fillet of slide 2
create vertex {-R_offset_1} {L_offset_1 + R_slot_1 + L_slot_1} 0
create vertex {0} {L_offset_1 + R_slot_1 + L_slot_1} 0
create vertex {-R_offset_1 + R_offset_1 * sind(60)} {L_offset_1 + R_slot_1 + L_slot_1 + R_offset_1 * cosd(60)} 0
# point for spline for outlet
create vertex {0 + R_slot_1} {L_slot_1 + T_thick_1*0.98} 0
create vertex {W_slot_1 + R_slot_1} {L_slot_1 + T_thick_1} 0

create vertex {W_slot_1 + L_slide_1  -R_lip} {L_slot_1 + R_slot_1} 0
create vertex {W_slot_1 + L_slide_1 } {L_slot_1 + R_slot_1 - R_lip} 0
create vertex {W_slot_1 + L_slide_1  - R_lip} {L_slot_1 + R_slot_1 - R_lip} 0

# takeoff position
create vertex {takeoff_x = W_slot_1 + L_slide_1  - R_lip - L_takeoff_1} {takeoff_y = L_slot_1 + R_slot_1} 0
create vertex {W_slot_1 + L_slide_1  - R_lip - L_takeoff_1} {L_slot_1 + T_thick_1} 0

## static contact positon
create vertex {W_slot_1 + L_slide_1 } {L_slot_1 + R_slot_1 - R_lip - L_static} 0
## dca
create vertex {W_slot_1 + L_slide_1  + H_gap} {L_slot_1 + R_slot_1 - R_lip - L_static} 0
## web exit
create vertex {W_slot_1 + L_slide_1  + H_gap} {L_slot_1 + R_slot_1 + L_web_down} 0
# free surface position
create vertex {W_slot_1 + L_slide_1  + H_gap - h_web_1} {L_slot_1 + R_slot_1 + L_web_down} 0
# landing
create vertex {landing_x = W_slot_1 + L_slide_1} {L_slot_1 + R_slot_1 + T_thick_1 + L_landing} 0
create vertex {W_slot_1 + L_slide_1  + H_gap} {L_slot_1 + R_slot_1 + T_thick_1 + L_landing} 0
# point for spline for landing
create vertex {landing_x} {L_slot_1 + R_slot_1 + T_thick_1 + L_landing*0.9} 0
create vertex {landing_x - R_lip-H_gap*2.5} {L_slot_1 + R_slot_1 + T_thick_1*.8 + L_landing*0.0} 0


create curve vertex 1 2
create curve vertex 1 3
create curve vertex 2 4
create curve vertex 3 4
create curve arc center vertex 6  4  5
create curve vertex 8 2
create curve arc center vertex 7  8  9
create curve spline vertex 9 10 11
create curve vertex 5 11
create curve vertex 5 15
create curve vertex 15 16
create curve vertex 16 11
create curve vertex 15 12
create curve arc center vertex 14  12  13

create curve vertex 13 17  
create curve vertex 17 18  
create curve vertex 18 22  
create curve vertex 22 21  
create curve spline vertex 16 24 23 21  
create curve vertex 22 19  
create curve vertex 19 20  
create curve vertex 20 21  


create surface curve 2 4 3 1  
create surface curve 3 5 9 8 7 6  
create surface curve 9 10 11 12  
create surface curve 13 14 15 16 17 18 19 11  
create surface curve 18 20 21 22  

imprint all
merge all

block 1 surface 1
block 2 surface 2
block 3 surface 3
block 4 surface 4
block 5 surface 5
block all element type quad9

# die 
sideset 3 add curve 4 5 10 13 14 15
nodeset 3 add curve 4 5 10 13 14 15

# inlet
sideset 1 add curve 2
nodeset 1 add curve 2

# outlet
sideset 2 add curve 21
nodeset 2 add curve 21

# die for slide 2
sideset 4 add curve 1 6 7
nodeset 4 add curve 1 6 7

# free surface
sideset 5 add curve 8 12 19 22
nodeset 5 add curve 8 12 19 22

sideset 51 add curve 8
nodeset 51 add curve 8

sideset 52 add curve 12
nodeset 52 add curve 12

#sideset 53 add curve 19 
#nodeset 53 add curve 19

sideset 54 add curve 19 22
nodeset 54 add curve 19 22

# web
sideset 6 add curve 17 20
nodeset 6 add curve 17 20

# upstream meniscus
sideset 7 add curve 16
nodeset 7 add curve 16

#
# CAP_ENDFORCE
nodeset 100 vertex 20

# SCA
nodeset 200 vertex 17

#DCA
nodeset 300 vertex 18

# SCA slide wall
nodeset 400 vertex 9

# mesh fence
# yplane
sideset 800 curve 3
nodeset 800 curve 3

sideset 805 curve 18
nodeset 805 curve 18

#xplane
sideset 700 curve 9
nodeset 700 curve 9

sideset 705 curve 11
nodeset 705 curve 11

surface all size 0.01
mesh surface all

export mesh "single.g" dimension 2 overwrite




