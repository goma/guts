{
  "name": "overset_ball",
  "description": "*********************************************************\n\t*\t\t\t\t\t\t\t*\n\t*\tSolid ball falling through a cylindrical\t*\n\t*\tcolumn of liquid, with fully-coupled stress.  \t*\n\t*\tTest of Goma overset grid AC algorithm.\t\t*\n\t*\t\t\t\t\t\t\t*\n\t*********************************************************",
  "contact": {
    "name": "Goma Developers",
    "email": "contact@gomafem.com"
  },
  "estimated_time_minutes": 1,
  "disabled": false,
  "features": [
    "serial",
    "transient",
    "overlapping_meshes",
    "umf",
    "cylindrical",
    "moving_mesh",
    "2d",
    "no_chemkin"
  ],
  "requirements": {
    "max_prob_var": 7,
    "max_conc": 2,
    "mde": 12,
    "solver_package": "umf",
    "use_arpack": "no",
    "enable_omega_h": ""
  },
  "run": {
    "use_aprepro": false,
    "aprepro_flags": "",
    "use_chemkin": false,
    "chemkin_input": "",
    "use_mpi": false,
    "num_processors": 1,
    "use_decomp": false,
    "brk_input": "",
    "brk_exo_in": "",
    "fix_exo_basename": "",
    "goma_input": "ball.input",
    "goma_serr": "stderr.txt",
    "goma_sout": "stdout.txt",
    "goma_opts": ""
  },
  "blessed": {
    "serr": "blessed.stderr.txt",
    "sout": "blessed.stdout.txt",
    "exo_output": [
      "out.exoII"
    ],
    "blessed_exo_output": [
      "blessed.exoII"
    ],
    "exo_abs_tol": [
      1e-11
    ],
    "exo_rel_tol": [
      0.001
    ],
    "exodiff_input_file": [
      "exodiff.inp"
    ]
  },
  "extra": {
    "whacked_files": [],
    "extra_tests": false,
    "extra_test_scripts": []
  }
}
