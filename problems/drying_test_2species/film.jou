nodeset associativity on
set associativity complete on

########## Geometry parameters in MM G S ##########

#{include(props.incl)}

########## 

create vertex 0 0 
create vertex 0 {H_film}
create vertex {H_t} {H_film}
create vertex {H_t} 0 
create vertex {H_t} {-H_sub}
create vertex 0 {-H_sub}

create curve 1 2 
create curve 2 3 
create curve 3 4 
create curve 4 1
create curve 1 6 
create curve 6 5
create curve 5 4

create surface 1 2 3 4
create surface 4 5 6 7 

merge all

########## Mesh Parameters ############

curve 1 interval {ints}
curve 2 interval {sints}
curve 3 interval {ints}
curve 4 interval {sints}
curve 5 interval {ints}
curve 6 interval {sints}
curve 7 interval {ints}

########## Meshing ################

mesh surface 1 2

########## Assign Nodesets and Sidesets ###########

nodeset 5 curve 1
nodeset 4 curve 2
nodeset 2 curve 3 
nodeset 7 curve 4
nodeset 1 curve 6

nodeset 10 vertex 6 
nodeset 20 vertex 5
nodeset 30 vertex 4
nodeset 60 vertex 1
nodeset 70 vertex 3
nodeset 80 vertex 2


sideset 500 curve 1
sideset 400 curve 2
sideset 200 curve 3
sideset 700 curve 4
sideset 100 curve 6

sideset 1000 curve 1 5
sideset 2000 curve 3 7

block 1 surface 2
block 2 surface 1

block 1 2 element type QUAD4

################ Save the Mesh ##########

export genesis "film.exoII" dimension 2 overwrite
