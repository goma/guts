Material Data File for Suspension

/**********Form of each property card *********/
PROPERTY   = MODEL   FLOAT#1 FLOAT#2 .....FLOAT#5

/**********Form of each Constitutive card *********/
MECHANICS_TYPE   = MODEL 

Of the many available options, MODEL can be USER
/************************************************/

---Physical Properties
Density		= CONSTANT 1.

---Mechanical Properties and Constitutive Equations
Solid Constitutive Equation 	= NONLINEAR	
Convective Lagrangian Velocity  = NONE
Lame MU 			= CONSTANT 	1.
Lame LAMBDA 			= CONSTANT 	1.
Stress Free Solvent Vol Frac	= CONSTANT	0.
#Liquid Constitutive Equation 	= NEWTONIAN
Liquid Constitutive Equation 	= SUSPENSION
Low Rate Viscosity		= CONSTANT	46.
#Viscosity                       = CONSTANT	46.
Power Law Exponent	 	= CONSTANT	-1.82
Suspension Maximum Packing	= CONSTANT	0.58
Suspension Species Number       = 0
Polymer Constitutive Equation   = NOPOLYMER

---Thermal Properties
Conductivity		= CONSTANT	1.
Heat Capacity		= CONSTANT   	1.
Volume Expansion	= CONSTANT	1.
Reference Temperature	= CONSTANT	0.
Liquidus Temperature	= CONSTANT	1.
Solidus Temperature	= CONSTANT	1.

---Electrical Properties
Electrical Conductivity = CONSTANT      1

---Microstructure Properties
Media Type              = CONTINUOUS
Permeability		= CONSTANT	1.
Porosity                = CONSTANT    0.9
FlowingLiquid Viscosity   = CONSTANT    1.0
Inertia Coefficient       = CONSTANT    0.0

${Kc=0.41}
${Keta=0.62}
${a=50e-4}
${Kr=0.}
${Dx=1.e-2}
${Dy=1.e-2}
${Dz=0.00}
${Dg=0.}

---Species Properties
#Diffusion Constitutive Equation = FICKIAN
Diffusion Constitutive Equation = HYDRODYNAMIC
#Species Weight Function         = SUPG  0.1
Species Weight Function         = GALERKIN
#Diffusivity  			= CONSTANT  0  1.
Diffusivity		  	= HYDRO 0 
Shear Rate Diffusivity          = CONSTANT 0 {Kc*a*a}
Viscosity Diffusivity           = CONSTANT 0 {Keta*a*a}
Curvature Diffusivity           = CONSTANT 0 {Kr*a*a}
Fickian Diffusivity             = ANISOTROPIC 0 {Dx} {Dy} {Dz}  
Gravity-based Diffusivity       = CONSTANT 0 {Dg}
Species Time Integration 	= STANDARD  0
Advective Scaling		= CONSTANT  0	1.
Latent Heat Vaporization	= CONSTANT  0	0.
Latent Heat Fusion		= CONSTANT  0	0.
Vapor Pressure  		= CONSTANT  0	0.
Species Volume Expansion	= CONSTANT  0	0.
Reference Concentration         = CONSTANT  0   0.35
Diffusivity		  	= HYDRO 1
Shear Rate Diffusivity          = CONSTANT 1 {Kc*a*a}
Viscosity Diffusivity           = CONSTANT 1 {Keta*a*a}
Curvature Diffusivity           = CONSTANT 1 {Kr*a*a}
Fickian Diffusivity             = ANISOTROPIC 1 {Dx} {Dy} {Dz}  
Gravity-based Diffusivity       = CONSTANT 1 {Dg}
Species Time Integration 	= STANDARD  1
Advective Scaling		= CONSTANT  1	1.
Latent Heat Vaporization	= CONSTANT  1	0.
Latent Heat Fusion		= CONSTANT  1	0.
Vapor Pressure  		= CONSTANT  1	0.
Species Volume Expansion	= CONSTANT  1	0.
Reference Concentration         = CONSTANT  1   0.35

