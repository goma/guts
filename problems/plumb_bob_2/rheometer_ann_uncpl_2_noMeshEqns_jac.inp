 FEM File Specifications
 ---
FEM file                         = rheometer_ann.gen
Output EXODUS II file            = rheometer_ann_uncpl_2_jac.exoII
GUESS file                       = contin.dat
SOLN file                        = soln.dat
Write intermediate results       = no
 ---
General Specifications
 ---
Number of processors             = 1
Output Level                     = 0
Debug                            = -2
Initial Guess                    = read_exoII_file rheometer_ann_uncpl_2_sav.exoII
 --- 
Time Integration Specifications
 ---
Time integration                 = steady
delta_t                          = 5.e-04
Maximum number of time steps     = 200
Maximum time                     = 405.0e+0
Minimum time step                = 1.0e-9
Time step parameter		 = 0.
Time step error                  = 1.1 0 1 0 0 0 0
Printing Frequency		 = 1
 ---
Solver Specifications
 ---
Solution Algorithm               = umf
Preconditioner                   = ilu
Size of Krylov subspace          = 15
Orthogonalization                = classical
Maximum Linear Solve Iterations  = 1000
Preconditioner                   = poly
Polynomial                       = LS,1
Size of Krylov subspace          = 64
Orthogonalization                = classical
Maximum Linear Solve Iterations  = 1000
Number of Newton Iterations      = 20
Newton correction factor         = 1
Normalized Residual Tolerance    = 1e-12
Residual Ratio Tolerance         = 1e-3

Pressure Stabilization           = no
Pressure Stabilization Scaling   = 1.

Number of augmenting conditions = -1
$AC = VC   {mat_id = 1} {volid = 1} {bcid = 16  } {dfid=0} {compid = 0} {const =
1.5*2.}
END OF AC


 ---
Boundary Condition Specifications
 ---
Number of BC			 =    -1

BC = PLANE  SS 3  0.00 1.0 0.  -0.3

BC = PLANE  SS 1  1.0 .0 0.  1.5

BC = PLANE SS 2   0. 1. 0. -2.3

$bottom of cup
BC = U  NS 1  0.0
BC = V  NS 1  0.0
BC = GD_LINEAR SS 1 R_MOMENTUM3 0 VELOCITY3  0 0. -1.
BC = GD_LINEAR SS 1 R_MOMENTUM3 0 MESH_POSITION2 0 0. 0.005

$center plane
BC = U  NS 3 0.0
BC = V  NS 3  0.0
BC = W  NS 3 {0.3*0.005}

$BC = W NS 1 0.0

#Outer edge of cup
BC = W NS 2 {0.005*2.3}
$BC = W NS 2 0.0
BC = U NS 2 0.
BC = V NS 2 0.

BC = KINEMATIC  SS 4  0. 0.
#BC = CAPILLARY   SS  4  40.0  0.  0.0
BC = CAPILLARY   SS  4  40.0E-5  0.  0.0
$BC = CAPILLARY_SHEAR_VISC SS 4 500. 0.001

BC = CA NS 10 1.5707 0 -1 0

BC = P NS 30 3.1E-3

$ Note you must have the U=0 at this corner since you've no kinbc
$BC = DX NS 10 0.
$BC = DY NS 10 0.
$BC = U NS 10 0.
BC = CA NS 20 1.5707 0 1 0

$plumb bob
$BC = U NS 4 0
$BC = V NS 4 0
$BC = W NS 4 {0.005*1.0}
$BC = W NS 4 0.
$BC = DX NS 4 0
$BC = DY NS 4 0

END OF BC


 

----
Problem Description
---
 
Number of Materials = 2
 
 MAT =   water    1
 
  Coordinate System =SWIRLING
  Element Mapping   = isoparametric
  Mesh Motion = ARBITRARY
  Number of bulk species = 0
 
        Number of EQ  = 6
        EQ = mesh1      Q2      D1      Q2    	     0.     0.    0.   1.   0.  0. 
        EQ = mesh2      Q2      D2      Q2           0.     0.    0.   1.   0.  0. 
        EQ = momentum1  Q2      U1      Q2    	     1.     1.    1.   1.   1.  0. 
        EQ = momentum2  Q2      U2      Q2           1.     1.    1.   1.   1.  0. 
        EQ = momentum3  Q2      U3      Q2           1.     1.    1.   1.   1.  0. 
        EQ = continuity Q1     P       Q1      1.                          0.
                              			div  ms  adv   bnd  dif    src   porous

#
#          You need the mesh equations on shell 
#
 MAT =   surface    2
 
  Coordinate System =SWIRLING
  Element Mapping   = isoparametric
  Mesh Motion = ARBITRARY
  Number of bulk species = 0
 
        Number of EQ  = 1
     #   EQ = mesh1      Q2      D1      Q2    	     0.     0.    0.   1.   0.  0. 
     #   EQ = mesh2      Q2      D2      Q2           0.     0.    0.   1.   0.  0. 
        EQ = n_dot_curl_v Q2    gamma4 Q2             1.

Post Processing Specifications

Stream Function = no
# Have to have this on!
Vorticity Vector = yes
Streamwise normal stress = no
Pressure contours = yes
Second Invarient of Strain = no
Mesh Dilatation = no
Navier Stokes Residuals = no
Moving Mesh Residuals = no
Mass Diffusion Vectors = no
Mass Fluxlines = no
Energy Conduction Vectors = no
Energy Fluxlines = no
Time Derivatives = no
Mesh Stress Tensor = no
Mesh Strain Tensor = no


