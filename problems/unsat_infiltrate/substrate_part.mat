
Material Data File for Substrate

/**********Form of each property card *********/
PROPERTY   = MODEL   FLOAT#1 FLOAT#2 .....FLOAT#5

/**********Form of each Constitutive card *********/
MECHANICS_TYPE   = MODEL 

Of the many available options, MODEL can be USER
/************************************************/


---Physical Properties
Density			= CONSTANT 0.998

---Mechanical Properties and Constitutive Equations
#Solid Constitutive Equation 	= NONLINEAR	
Solid Constitutive Equation 	= INCOMP_PSTRAIN	
Lame MU 			= CONSTANT 	10000000000.
Lame LAMBDA 			= CONSTANT 	10000000000.
Stress Free Solvent Vol Frac	= CONSTANT	0.1
Liquid Constitutive Equation 	= NEWTONIAN
Viscosity			= CONSTANT	1130.E-5
Low Rate Viscosity		= CONSTANT	0.
Power Law Exponent		= CONSTANT	0.
High Rate Viscosity		= CONSTANT	0.
Time Constant			= CONSTANT	0.
Aexp 				= CONSTANT	0.
Surface Tension			= CONSTANT	2.2e-07

---Thermal Properties
Conductivity		= CONSTANT	1.
Heat Capacity		= CONSTANT	1.
Volume Expansion	= CONSTANT	1.
Reference Temperature	= CONSTANT	0.
Liquidus Temperature	= CONSTANT	1.
Solidus Temperature	= CONSTANT	1.
 
---Electrical Properties
Electrical Conductivity = CONSTANT      1.

#
###############################################################3
#
---Microstructure Properties
#
#  Two phase flow with no pressure gradient in the
#  gas phase
#
Media Type              = POROUS_UNSATURATED
#
# Porosity: obtained from Table 1: Martinez [1]
#
Porosity                = CONSTANT    0.43
#
#  Permeability =  Obtained from the saturated conductivity 
#                  from Table 1: Martinez [1]
#                  (units of cm * cm )
#
#       K_s = 8.2E-3 cm/sec = rho_l g k / mu_l
#
#       where g = 980 cm /sec^2
#             rho_l = 0.998 gm/cm^3
#             mu_l  = 1130.0E-5 gm/(cm * sec) 
#                   = viscoscity of water at 293.15K and 1 atm.
#
Permeability		= CONSTANT       9.4741E-8
#
# Capillary Network Stress:
#      Irrelevant for current problem
#
Capillary Network Stress = PARTIALLY_WETTING
#
# Rel Gas Permeability =
#   This quantity is irrelevant for the current problem
#   However, we will fill it in with consistent values 
#    SUM_TO_ONE: this means that the relative gas permeability
#                and the relative liquid permeability will
#                sum to one. relative liquid permeability
#                is given by Van Genuchten model.
#             The other parameter on the line is the
#             gas phase viscosity = 18.6E-5 gm/(cm * sec)
#                (air at 300K and 1 atm).
#
Rel Gas Permeability     = SUM_TO_ONE    18.6E-5 
#
#
# Rel Liq Permeability:  Van Genuchten Model = Table 1 Martinez [1]
#
#           S_r = irreducible water saturation = 0.1
#           S_g = irreducible gas saturation   = 0.0
#           Beta = exponenent in the model     = 2.0
#           1.0 - 1.0/Beta                     = 0.5
#           mu_l    = 859.0E-5 gm/(cm * sec) 
#                   = viscoscity of water at 300K and 1 atm.
#
Rel Liq Permeability	 = VAN_GENUCHTEN  0.1 0. 0.5 1130.0E-5
#
# Saturation: Van Genuchten Model = Table 1 Martinez [1]
#
#           S_r = irreducible water saturation = 0.1
#           S_g = irreducible gas saturation   = 0.0
#           Beta = exponenent in the model     = 2.0
#           alpha = scaling factor to convert from
#                   capillary pressure to suction
#                 = 0.1 1/meters = 1.0E-3 cm-1
#           alpha/rho_l = 1.002E-3 cm-1 * cm**3 / 1 gm = 1.002E-3 cm**2 / gm
#           alpha/(rho_l*g) = 1.0224E-6 gm cm-3 sec-2
#
#
Saturation          	 = VAN_GENUCHTEN  0.1 0. 2.0 1.0224E-6
#
############################################################################
#
---Porous Properties
Porous Diffusion Constitutive Equation = DARCY_FICKIAN
Porous Weight Function	   	       = GALERKIN  0.0
Porous Mass Lumping                    = FALSE
Porous Gas Diffusivity                 = CONSTANT  0  0.0
Porous Latent Heat Vaporization        = CONSTANT  0  0.
Porous Latent Heat Fusion              = CONSTANT  0  0.
Porous Vapor Pressure                  = NON_VOLATILE 0   29. 8.314E7 293.15
Porous Liquid Volume Expansion         = CONSTANT  0  1.

***Species Number (all zero for primary liquid solvent)****|

--Porous Gas-inert properties
Porous Gas Constants           = IDEAL_GAS   29 8.314E7 293.15 1.013250E6
#
############################################################################
#
---Species Properties
Diffusion Constitutive Equation = DARCY
# Species Weight Function		= SUPG          1.0
Species Weight Function		= GALERKIN     0.0 
Species Time Integration        = TAYLOR_GALERKIN 0

********Species Number**********************|

Diffusivity  			= CONSTANT  0   0.3
Latent Heat Vaporization	= CONSTANT  0	0.
Latent Heat Fusion		= CONSTANT  0	0.
#
# Vapor Pressure
#
Vapor Pressure                  = FLAT      0  1.0133E4 1.0 18 8.314E7 293.15 29 1.0133E6 
Species Volume Expansion	= CONSTANT  0   1.
Reference Concentration         = CONSTANT  0   0.

********Species Number**********************|
#
############################################################################
#
----Source Terms--
Navier-Stokes Source		= CONSTANT	980.   0.  0.
Solid Body Source		= CONSTANT	0.  0.  0.
Mass Source			= CONSTANT	0.
Heat Source			= CONSTANT	0.
Species Source			= CONSTANT  0   0.
Current Source                  = CONSTANT      0.
#
###################################################################
#
# Initialization section
#
# Initialize  for a capillary pressure of Pc = 1.689842E6
#      using pg = 1 atm = 1.013250E6 erg/cm**2
#      This corresponds to an initial saturation of around 0.55
#
Initialize =  POR_LIQ_PRES 0 -0.676592E6
#
##################################################################
