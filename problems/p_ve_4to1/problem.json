{
  "name": "p_ve_4to1",
  "description": "##########################################################\n#\n#          Giesekus Fluid in 4-to-1 Contraction\n#\n##########################################################",
  "contact": {
    "name": "Goma Developers",
    "email": "contact@gomafem.com"
  },
  "estimated_time_minutes": 4,
  "disabled": false,
  "features": [
    "parallel",
    "steady",
    "gmres",
