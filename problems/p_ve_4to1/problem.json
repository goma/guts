  },
  "run": {
    "use_aprepro": false,
    "aprepro_flags": "",
    "use_chemkin": false,
    "chemkin_input": "",
    "use_mpi": true,
    "num_processors": 2,
    "use_decomp": false,
    "brk_input": "brk_vps.in",
    "brk_exo_in": "four_one.exoII",
    "fix_exo_basename": "newt",
    "goma_input": "p_newt.input",
    "goma_serr": "stderr.txt",
    "goma_sout": "stdout.txt",
    "goma_opts": ""
  },
  "blessed": {
    "serr": "blessed.stderr.txt",
    "sout": "blessed.stdout.txt",
    "exo_output": [
      "newt.exoII"
    ],
    "blessed_exo_output": [
      "blessed.exoII"
    ],
    "exo_abs_tol": [
      1e-11
    ],
    "exo_rel_tol": [
      0.001
    ],
    "exodiff_input_file": [
      ""
