$
$ 	x_origin = {x_origin = 0}
$ 	y_origin = {y_origin = 0}
$ 	width    = {width    = 2}
$ 	height1  = {height1  = 1}
$       height2  = {height2  = 2}
$       angle    = {angle = 0.0}
$
$	Recipe for building up box corners from these specifications...
$
$	{x_1 = x_origin}
$	{y_1 = y_origin}
$
$	{x_2 = x_1 + width }
$	{y_2 = y_1 }
$
$	{x_3 = x_1 }
$	{y_3 = y_1 + height1 }
$
$	{x_4 = x_2 }
$	{y_4 = y_2 + height1 }
$
