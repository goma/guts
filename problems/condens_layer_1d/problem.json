  "run": {
    "use_aprepro": true,
    "aprepro_flags": "",
    "use_chemkin": false,
    "chemkin_input": "",
    "use_mpi": false,
    "num_processors": 1,
    "use_decomp": false,
    "brk_input": "",
    "brk_exo_in": "",
    "fix_exo_basename": "",
    "goma_input": "condens1dp_5b.gap",
    "goma_serr": "stderr.txt",
    "goma_sout": "stdout.txt",
    "goma_opts": ""
  },
  "blessed": {
    "serr": "blessed.stderr.txt",
    "sout": "blessed.stdout.txt",
    "exo_output": [
      "condens1dp_o_b.exoII"
    ],
    "blessed_exo_output": [
      "blessed.exoII"
    ],
    "exo_abs_tol": [
      1e-11
    ],
    "exo_rel_tol": [
      0.001
    ],
    "exodiff_input_file": [
      "exodiff.inp"
    ]
  },
  "extra": {
    "whacked_files": [],
    "extra_tests": false,
    "extra_test_scripts": []
  }
