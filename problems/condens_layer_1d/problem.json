{
  "name": "condens_layer_1d",
  "description": "#################################################\n#\n#          Condensation problem using \n#          Discontinuous variables and the \n#          DISCONTINUOUS_VELO bc\n#\n################################################",
  "contact": {
    "name": "Goma Developers",
    "email": "contact@gomafem.com"
  },
  "estimated_time_minutes": 2,
  "disabled": false,
  "features": [
    "discontinuous_variables",
    "transient",
    "species",
    "umf",
    "moving_mesh",
    "2d",
    "serial",
    "cartesian",
    "no_chemkin"
