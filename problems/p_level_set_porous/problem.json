{
  "name": "p_level_set_porous",
  "description": "Partially saturated porous media with level sets,\nusing Amesos parallel direct solver on 2 processors.",
  "contact": {
    "name": "Goma Developers",
    "email": "contact@gomafem.com"
  },
  "estimated_time_minutes": 3,
  "disabled": false,
  "features": [
    "trilinos",
    "transient",
    "level_set",
    "porous_media",
    "parallel",
    "2d",
    "cylindrical",
    "no_chemkin"
  ],
  "requirements": {
    "max_prob_var": 6,
    "max_conc": 1,
    "mde": 12,
    "solver_package": "unknown",
    "use_arpack": "no",
    "enable_omega_h": ""
  },
  "run": {
    "use_aprepro": true,
    "aprepro_flags": "",
    "use_chemkin": false,
    "chemkin_input": "",
    "use_mpi": true,
    "num_processors": 2,
    "use_decomp": false,
    "brk_input": "brk_udp.in",
    "brk_exo_in": "restart.exoII",
    "fix_exo_basename": "out1",
    "goma_input": "input_axi_restart",
    "goma_serr": "stderr.txt",
    "goma_sout": "stdout.txt",
    "goma_opts": ""
  },
  "blessed": {
    "serr": "blessed.stderr.txt",
    "sout": "blessed.stdout.txt",
    "exo_output": [
      "out1.exoII"
    ],
    "blessed_exo_output": [
      "blessed.exoII"
    ],
    "exo_abs_tol": [
      1e-11
    ],
    "exo_rel_tol": [
      0.001
    ],
    "exodiff_input_file": [
      "exodiff.inp"
    ]
  },
  "extra": {
    "whacked_files": [],
    "extra_tests": false,
    "extra_test_scripts": []
  }
}
