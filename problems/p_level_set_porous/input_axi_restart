Boundary Condition Specifications
-------- --------- --------------
Number of BC                     = -1
######################################
## Level Set BC's

# Interface of porous & fluid

##{h_elem = 0.1}
BC = POR_LIQ_FLUX_FILL SS 100 1 2 {permeab/lqvisc/(h_elem/2.0)} {-pcmin}  {dt_min/100.0} {LSLS/2.0}
BC = DARCY_CONTINUOUS SS 100 1 2 {LSLS} {time_threshold = 0}
/* Notice the one-sided application of this */
$Must have this no-slippage on the porous-continuous interface. 
BC = LINEAR_WETTING_SIC SS 100 {theta_s_ss100} {cT_ss100} {3.*LSLS} {1.e-8*L*L} 0.0 0.0 0.0 {dt_max/10.0}

# External wall for slip
BC = VELO_NORMAL SS 150 0.0
$BC = U NS 150 0.
$BC = V NS 150 0.

# Free Surface
BC = LS_CAPILLARY LS 0

# Entrance BC
#BC = FLOW_PRESSURE SS 200 1.0
BC = U NS 200 -0.2
BC = V NS 200 0.0

#Exit BC
BC = VELO_TANGENT SS 500 0 0. 0. 0.


## Symmetry Plane BC's
$BC = VELO_NORMAL SS 400 0.0
BC = V NS 400 0.0
END OF BC
######################################

