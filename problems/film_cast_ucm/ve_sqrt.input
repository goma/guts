    EQ = momentum2  Q2	U2 Q2	     0.    0.   1.   1.   1.   0.
    EQ = film_height Q1	FILM_HEIGHT  Q1	  1. 1. 1. 1. 1.
    EQ = mesh1      Q2 D1 Q2        0. 0. 1. 1. 1.
    EQ = mesh2      Q2  D2 Q2        0. 0. 1. 1. 10.
