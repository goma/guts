#!python

create vertex -0.25 0.5 0
create vertex 0.25 0.5 0
create vertex 0.25 -0.5 0
create vertex -0.25 -0.5 0

create curve vertex 1 vertex 2
create curve vertex 2 vertex 3
create curve vertex 3 vertex 4
create curve vertex 4 vertex 1

create surface curve 1 2 3 4

imprint all
merge all

curve 1 3 interval 1
curve 2 4 interval 50

curve 1 2 3 4 scheme bias 1.0

mesh surface 1

block 1 surface 1

block 1 element type quad9

sideset 1 curve 1
sideset 2 curve 2
sideset 3 curve 3
sideset 4 curve 4
nodeset 1 curve 1
nodeset 2 curve 2
nodeset 3 curve 3
nodeset 4 curve 4

export mesh "test_mesh.g" overwrite
