###
### Physical properties for solid aluminum block
###
{include(armature.apre)}

### Physical properties ###
Density                       = CONSTANT {density_al}

### Mechanical properties ###
Solid Constitutive Equation   = LINEAR
#Lame MU                       = CONSTANT {lame_mu_al}
Lame MU                       = TABLE 2 FAUX_PLASTIC 0 LINEAR FILE=stress_strain_comp.txt 
#Lame LAMBDA                   = CONSTANT {lame_mu_al}
Lame LAMBDA                   = POISSON_RATIO 0.33
Lame Temperature Shift        = CONSTANT 1.0
Stress Free Solvent Vol Frac  = CONSTANT 0.0

### Liquid properties ###
Liquid Constitutive Equation  = NEWTONIAN
Viscosity                     = CONSTANT 1.0
Surface Tension               = CONSTANT 1.0

### Thermal properties ### 
Conductivity                  = CONSTANT {T_cond_al}
Heat Capacity                 = CONSTANT {Cp_al}
Volume Expansion              = CONSTANT 1.0
Reference Temperature         = CONSTANT 0.0
Liquidus Temperature          = CONSTANT 1.0
Solidus Temperature           = CONSTANT 1.0

### Electrical properties ###
Electrical Conductivity       = CONSTANT {E_cond_al}

### Porous terms for linking lubrication to level set field ###
Media Type	 	      = POROUS_BRINKMAN
Porosity                      = CONSTANT 1.0
Permeability   		      = CONSTANT 1.0
Brinkman Porosity             = CONSTANT 1.0
Brinkman Permeability         = CONSTANT 1.0
FlowingLiquid Viscosity       = CONSTANT 0.0
Inertia Coefficient           = CONSTANT 0.0

### Source Terms ###
Navier-Stokes Source          = CONSTANT 0.0 0.0 0.0 
Solid Body Source             = CONSTANT 0.0 0.0 0.0
Mass Source                   = CONSTANT 0.0
Heat Source                   = CONSTANT 0.0
Current Source                = CONSTANT 0.0

