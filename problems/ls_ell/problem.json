{
  "name": "ls_ell",
  "description": "##########################################################\n#\n#     2D Test of Level Set  Advection in ell geometry\n#\n##########################################################",
  "contact": {
    "name": "Goma Developers",
    "email": "contact@gomafem.com"
  },
  "estimated_time_minutes": 2,
  "disabled": false,
  "features": [
    "transient",
    "front",
    "level_set",
    "serial",
    "2d",
    "cartesian",
    "no_chemkin"
  ],
  "requirements": {
    "max_prob_var": 4,
    "max_conc": 1,
    "mde": 12,
    "solver_package": "front",
    "use_arpack": "no",
    "enable_omega_h": ""
  },
  "run": {
    "use_aprepro": false,
    "aprepro_flags": "",
    "use_chemkin": false,
    "chemkin_input": "",
    "use_mpi": false,
    "num_processors": 1,
    "use_decomp": false,
    "brk_input": "",
    "brk_exo_in": "",
    "fix_exo_basename": "",
    "goma_input": "ell.inp",
    "goma_serr": "stderr.txt",
    "goma_sout": "stdout.txt",
    "goma_opts": ""
  },
  "blessed": {
    "serr": "blessed.stderr.txt",
    "sout": "blessed.stdout.txt",
    "exo_output": [
      "out.exoII"
    ],
    "blessed_exo_output": [
      "blessed.exoII"
    ],
    "exo_abs_tol": [
      1e-11
    ],
    "exo_rel_tol": [
      0.001
    ],
    "exodiff_input_file": [
      ""
    ]
  },
  "extra": {
    "whacked_files": [
      "SOLN.DAT",
      "level_renorm.dat",
      "level_set.dat",
      "ell.dat"
    ],
    "extra_tests": false,
    "extra_test_scripts": []
  }
}
