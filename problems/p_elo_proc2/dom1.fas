#
#
# $ Defs -- APREPRO definitions for 
$	        ELO Geometry central definitions file
$
$	       L_1
$
$	1
$	0
$
$ 	x_origin = 0
$ 	y_origin = 0
$
$ Distance from center of one hexagon to the other = D_hex = 35
#
# Half the distance from one hexagon to the other = L_hex = 17.5
#
# Distance from center of hexagon
#  to a vertex point of the hexagon = B_hex = 1.73205
#
# Height of the domain in the z direction = H_elo = 17.5
#
$      Base case 
#           mref = 0.1   gf = 0.95      elo_domain
#      R1 case
#           mref = 0.3   gf = 0.98      elo_domain_r1
$
$ Mesh discretization, grading...
$       mesh refinement = mref = 0.1
$	Number of elements in x direction = nx = 7
$	Number of elements in y direction in region 1 = ny1 = 4
$	Number of elements in y direction in region 2 = ny2 = 16
$       Number of elements in the z direction = nz = 18
$	Grading factor in z direction = 0.95
$	Material 1 is 1
$	Material 2 is 2

#
#
#
 TITLE 
 Coltrin's ELO Hexagonal domain - region 1
#
# Definition of Points
#  
 POINT     1     0.0                         0.0
 POINT     2    10.10362971          0.0
 POINT     3    0.7499996503   16.2009625
# POINT     4     0.0                        17.5 
 POINT     5     0.0                        15.76795 
#
#
# Definition of lines
#
 LINE      1   STR     1     2     0   7          1.0000
 LINE      2   STR     2     3     0   16          1.0000
 LINE      5   STR     5     1     0  16           1.0000
 LINE      6   STR     5     3     0  7           1.0000
#
#
# Definition of Gas Regions
#
 REGION     1     1    -1 -2 -6 -5
#
# Two triangular regions in the round corners of the susceptor
#

 SCHEME     0 M
 BODY       1
#
# Point Boundary Conditions
#  first one is symmetry point half way between each hexagon
#  second one is the center of the hexagon
#
POINBC     101   1
# POINBC     104   4
#
# Side Set 1 =  all regular
#
ELEMBC     1     1
#
# Side Set 2 = second side part hex, part regular
#
ELEMBC     2     2
#
# Side Set 3 = third side lying between hexagon centers
#              part hex part regular
#
ELEMBC     3     5
#
#  Common side between the two regions
#
ELEMBC     9     6
#
EXIT
