{
  "name": "p_elo_proc2",
  "description": "##############################################################\n\n           Example of a 3D mass transfer calculation\n\t   with boundary conditions of the third kind\n                 8 processor case\n\n##############################################################",
  "contact": {
    "name": "Goma Developers",
    "email": "contact@gomafem.com"
  },
  "estimated_time_minutes": 1900,
  "disabled": false,
  "features": [
    "parallel",
    "gmres",
    "steady",
    "species",
    "3d",
    "cartesian",
    "no_chemkin"
  ],
  "requirements": {
    "max_prob_var": 1,
    "max_conc": 1,
    "mde": 27,
    "solver_package": "aztec",
    "use_arpack": "no",
    "enable_omega_h": ""
  },
  "run": {
    "use_aprepro": false,
    "aprepro_flags": "",
    "use_chemkin": false,
    "chemkin_input": "",
    "use_mpi": true,
    "num_processors": 2,
    "use_decomp": false,
    "brk_input": "brk.in",
    "brk_exo_in": "elo_domain.exoII",
    "fix_exo_basename": "elo_domain_gout",
    "goma_input": "elo_domain.gin",
    "goma_serr": "stderr.txt",
    "goma_sout": "stdout.txt",
    "goma_opts": ""
  },
  "blessed": {
    "serr": "blessed.stderr.txt",
    "sout": "blessed.stdout.txt",
    "exo_output": [
      "elo_domain_gout.exoII"
    ],
    "blessed_exo_output": [
      "blessed.exoII"
    ],
    "exo_abs_tol": [
      1e-11
    ],
    "exo_rel_tol": [
      0.001
    ],
    "exodiff_input_file": [
      "exodiff.inp"
    ]
  },
  "extra": {
    "whacked_files": [],
    "extra_tests": false,
    "extra_test_scripts": []
  }
}
