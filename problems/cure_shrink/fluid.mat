{Include(params)}

Material Data File for SAMPLE

/**********Form of each property card *********/
PROPERTY   = MODEL   FLOAT#1 FLOAT#2 .....FLOAT#5

/**********Form of each Constitutive card *********/
MECHANICS_TYPE   = MODEL 

Of the many available options, MODEL can be USER
/************************************************/


---Physical Properties
Density			= CURE_SHRINKAGE 1000 2000 1 {cure_gel_pt} {cure_gel_pt}

---Mechanical Properties and Constitutive Equations
Solid Constitutive Equation 	= LAGRANGIAN	
Convective Lagrangian Velocity	= NONE
#Lame MU 			= CONSTANT      1.0
Lame MU = MULTI_CONTACT_LINE 1 200.0 0.02 2 3 
Lame LAMBDA 			= CONSTANT 	1.0
#Lame MU				= TABLE 2 Y 0 LINEAR FILE=linear_mu.txt
#Lame MU				= TABLE 2 Y 0 LINEAR FILE=sigmoidal_mu.txt
#Lame LAMBDA				= TABLE 2 MASS_FRACTION 1 LINEAR FILE=linear_lambda.txt
#Lame MU				= TABLE 2 Y 0 LINEAR FILE=photo_rheology_sept_2023_lame_mu_Pa.txt
#Lame LAMBDA				= TABLE 2 Y 0 LINEAR FILE=photo_rheology_sept_2023_lame_lambda_Pa.txt
Lame Temperature Shift = CONSTANT 0.0
#Stress Free Solvent Vol Frac	= CONSTANT	0.0
#Solid Thermal Expansion = CONSTANT_DV 0.0
#Solid Reference Temperature = CONSTANT 273.0


#Liquid Constitutive Equation 	= NEWTONIAN
#Viscosity			= CONSTANT      {500000.0}
#Low Rate Viscosity		= CONSTANT	0.
#Power Law Exponent		= CONSTANT	0.
#High Rate Viscosity		= CONSTANT	0.
#Time Constant			= CONSTANT	0.
#Aexp 				= CONSTANT	0.

Liquid Constitutive Equation 	= CURE
Low Rate Viscosity		= CONSTANT	{viscosity}
Cure Gel Point			= CONSTANT	{cure_gel_pt}
Cure A Exponent			= CONSTANT	{cure_A_exp}
Cure B Exponent			= CONSTANT	{cure_B_exp}
Cure Species Number		= 0
Cure Maximum Viscosity          = 5e6
Unreacted Gel Temperature = CONSTANT 273.0
Polymer Constitutive Equation   = NOPOLYMER
Surface Tension = CONSTANT 0.001

---Thermal Properties
Conductivity		= CONSTANT 	0.10
Heat Capacity		= CONSTANT	1.0
#Volume Expansion	= CONSTANT	1.0
Volume Expansion	= CONSTANT	0.00
Reference Temperature	= CONSTANT	{1.0}
Liquidus Temperature	= CONSTANT	1.
Solidus Temperature	= CONSTANT	1.
Energy Weight Function = SUPG 1.

---Electrical Properties
Electrical Conductivity = CONSTANT	1.0

---Microstructure Properties
Media Type		= CONTINUOUS
Porosity                = CONSTANT     1.0
Permeability		= CONSTANT	9.

---Brinkman-equation parameters
Brinkman Porosity   =  CONSTANT     1.0
Brinkman Permeability   =  CONSTANT     0.9
FlowingLiquid Viscosity   =  CONSTANT     1.5
Inertia Coefficient   =  CONSTANT     0.

---Species Properties
Diffusion Constitutive Equation = FICKIAN
Species Weight Function = SUPG 1.
Diffusivity  			= CONSTANT  0   1.
Latent Heat Vaporization	= CONSTANT  0	0.
Latent Heat Fusion		= CONSTANT  0	0.
Vapor Pressure  		= CONSTANT  0	0.
#Species Volume Expansion        = PHOTO_CURING  0.   -0.06
Species Volume Expansion        = PHOTO_CURING  0.   0.0
Reference Concentration         = CONSTANT  0   0.
				            
********Species Number**********************|

----Source Terms
Navier-Stokes Source		= CONSTANT	 0.0 -0.1 0.0 
Solid Body Source		= CONSTANT	0.  0.  0.
Mass Source			= CONSTANT	0.
#Heat Source			= CONSTANT	1000.0
Heat Source			= EPOXY	100000.0
#Species Source			= CONSTANT  0  0.
# {R = 8.3144626}
# {A1 = 6.53e31} {E1=222431.955/R} {A2=5.41e3} {E2=51637.9185/R} {A_m = -0.05*0} {B_m = 18.06} {A_n = -0.09*0} {B_n = 30}
Species Source			= EPOXY_LINEAR_EXP  0 {A1} {E1} {A2} {E2} {A_m} {B_m} {A_n} {B_n}
Current Source			= CONSTANT	0.





