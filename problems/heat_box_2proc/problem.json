{
  "name": "heat_box_2proc",
  "description": "Simple 2 Processor Heat Transfer in a Box",
  "contact": {
    "name": "Goma Developers",
    "email": "contact@gomafem.com"
  },
  "estimated_time_minutes": 1,
  "disabled": false,
  "features": [
    "parallel",
    "steady",
    "gmres",
    "cartesian",
    "energy",
    "2d",
    "no_chemkin"
  ],
  "requirements": {
    "max_prob_var": 1,
    "max_conc": 1,
    "mde": 12,
    "solver_package": "aztec",
    "use_arpack": "no",
    "enable_omega_h": ""
  },
  "run": {
    "use_aprepro": true,
    "aprepro_flags": "",
    "use_chemkin": false,
    "chemkin_input": "",
    "use_mpi": true,
    "num_processors": 2,
    "use_decomp": false,
    "brk_input": "box.brk",
    "brk_exo_in": "box3x3.exoII",
    "fix_exo_basename": "box3x3out",
    "goma_input": "box-2proc.goma",
    "goma_serr": "stderr.txt",
    "goma_sout": "stdout.txt",
    "goma_opts": ""
  },
  "blessed": {
    "serr": "blessed.stderr.txt",
    "sout": "blessed.stdout.txt",
    "exo_output": [
      "box3x3out.exoII"
    ],
    "blessed_exo_output": [
      "blessed.exoII"
    ],
    "exo_abs_tol": [
      1e-11
    ],
    "exo_rel_tol": [
      0.001
    ],
    "exodiff_input_file": [
      "exodiff.inp"
    ]
  },
  "extra": {
    "whacked_files": [],
    "extra_tests": false,
    "extra_test_scripts": []
  }
}
