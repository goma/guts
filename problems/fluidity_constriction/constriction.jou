#{include(params)}
undo on
reset
create vertex 0 0 0
create vertex {inlet_length} 0 0
create vertex {inlet_length+constriction_length} 0 0
create vertex {inlet_length+constriction_length+outlet_length} 0 0
create vertex 0 {R} 0
create vertex {inlet_length} {R} 0
create vertex {inlet_length+constriction_length} {R} 0
create vertex {inlet_length+constriction_length+outlet_length} {R} 0
create vertex {inlet_length+constriction_length/2} {R_constriction} 0
create vertex {inlet_length+constriction_length/spline_offset_size} {spline_initial_position} 0
create vertex {inlet_length+(spline_offset_size-1)*constriction_length/spline_offset_size} {spline_initial_position} 0
create curve spline vertex 6 10 9 11 7 delete
create curve vertex 1 2
create curve vertex 2 3
create curve vertex 3 4
create curve vertex 1 5
create curve vertex 5 6
create curve vertex 7 8
create curve vertex 4 8
create curve vertex 2 6
create curve vertex 3 7
create surface curve 2 5 6 9
create surface curve 1 3 9 10
create surface curve 4 7 8 10 	
merge curve 9 11
merge curve 10 12

curve 9 interval {y_interval}
curve 9 scheme bias factor {y_bias} start vertex 16
curve 5 interval {y_interval}
curve 5 scheme bias factor {y_bias} start vertex 5
curve 10 interval {y_interval}
curve 10 scheme bias factor {y_bias} start vertex 7
curve 8 interval {y_interval}
curve 8 scheme bias factor {y_bias} start vertex 8
curve 1 3 interval {constriction_interval}
curve 4 7 interval {in_out_interval}
curve 4 scheme bias factor {in_out_bias} start vertex 3
curve 7 scheme bias factor {in_out_bias} start vertex 7
curve 2 6 interval {in_out_interval}
curve 2 scheme bias factor {in_out_bias} start vertex 2
curve 6 scheme bias factor {in_out_bias} start vertex 16

mesh surface all

block 1 surface all
block 1 element type quad9

sideset 1 curve 2 3 4
sideset 2 curve 1 6 7
sideset 3 curve 5
sideset 4 curve 8
nodeset 1 curve 2 3 4
nodeset 2 curve 1 6 7
nodeset 3 curve 5
nodeset 4 curve 8

export mesh "constriction.g" dimension 2 overwrite
